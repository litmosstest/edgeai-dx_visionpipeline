# API and storage
VISION_HOST=0.0.0.0
VISION_PORT=8081
VISION_DATABASE_PATH=data/events.db
VISION_MEDIA_DIR=data/media

# RTSP camera input. Start MediaMTX, then publish a USB webcam to this path.
VISION_RTSP_URL=rtsp://localhost:8554/webcam
VISION_CAMERA_ID=usb-webcam-1
# Use "test" to publish a generated test pattern with scripts/stack.sh instead of a USB webcam.
VISION_PUBLISHER=webcam

# Runtime behavior
VISION_DEVICE=cuda
VISION_CAPTURE_FPS=8
VISION_SAMPLE_EVERY_N_FRAMES=8
VISION_MIN_CONFIDENCE=0.45
VISION_EVENT_COOLDOWN_SECONDS=8
# Set to 0 if you want make up to start services without starting frame processing.
VISION_STACK_START_PIPELINE=1

# Models. Install with: pip install -e '.[models]'
VISION_DETECTOR_BACKEND=yolo
VISION_DETECTOR_MODEL=yolo11n.pt
VISION_EMBEDDING_BACKEND=clip
VISION_EMBEDDING_MODEL=sentence-transformers/clip-ViT-B-32
VISION_VIDEO_EMBEDDING_BACKEND=frame_average
VISION_VIDEO_EMBEDDING_MODEL=microsoft/xclip-base-patch32
VISION_VIDEO_EMBEDDING_FRAMES=8

# VLM can stay template for a lightweight local demo, or transformers for a real model.
VISION_VLM_BACKEND=template
VISION_VLM_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
